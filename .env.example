# Copy to `.env` and fill in. Never commit `.env`.

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: Postgres (e.g. Railway DB proxy for local dev)
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# Public URL of the deployed Django app (Railway dashboard → your service → Networking).
# Used by the iOS app after running: python3 scripts/sync_ios_config.py
# SLATE_API_BASE_URL=https://your-service.up.railway.app
